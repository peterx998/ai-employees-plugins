{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-employees-plugins.example/schemas/common/customer.schema.json",
  "title": "Customer",
  "description": "Customer entity representing a registered customer in the system",
  "type": "object",
  "required": [
    "id",
    "name",
    "email",
    "country",
    "order_count",
    "total_spent",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the customer"
    },
    "name": {
      "type": "string",
      "description": "Full name of the customer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the customer"
    },
    "country": {
      "type": "string",
      "description": "Country of residence (ISO 3166-1 alpha-2 code)"
    },
    "order_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of orders placed by the customer"
    },
    "total_spent": {
      "type": "number",
      "minimum": 0,
      "description": "Total monetary amount spent by the customer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the customer account was created"
    }
  }
}
